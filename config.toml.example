# vps-monitor configuration

# Bind address — MUST be a loopback / private IP. Public binds (0.0.0.0, ::, public IPs) are rejected at startup.
bind = "127.0.0.1:8443"

# SQLite database path
db_path = "/var/lib/vps-monitor/db.sqlite"

# Session lifetime in seconds (default: 7 days)
session_ttl_secs = 604800

# Audit log retention in days
audit_retention_days = 90

# Failed-login lockout
max_failed_logins = 5
lockout_minutes = 15

# Path globs for PM2 log discovery (used when running user is not the PM2 user).
# If empty, fall back to `~/.pm2/logs` of the running user.
pm2_log_dirs = []

# Optional: override default docker socket path
# docker_socket = "/var/run/docker.sock"
